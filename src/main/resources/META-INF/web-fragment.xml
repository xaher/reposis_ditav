<web-fragment xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-fragment_3_0.xsd" version="3.0" metadata-complete="true"
>
    <name>reposis_ditav</name>

    <servlet>

        <servlet-name>DitavExportServlet</servlet-name>
        <servlet-class>de.gbv.reposis.ditav.DitavExportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DitavExportServlet</servlet-name>
        <url-pattern>/servlets/DitavExportServlet/</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DitavExportServlet</servlet-name>
        <url-pattern>/servlets/DitavExportServlet/*</url-pattern>
    </servlet-mapping>
    <filter>
        <filter-name>CORSFilterStarter</filter-name>
        <filter-class>de.gbv.reposis.ditav.CORSFilterStarter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CORSFilterStarter</filter-name>
        <url-pattern>/servlets/MCRDerivateContentTransformerServlet/*</url-pattern>
    </filter-mapping>


</web-fragment>
